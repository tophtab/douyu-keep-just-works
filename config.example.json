{
  "loginCookies": {
    "passport": "dy_did=YOUR_DY_DID; LTP0=YOUR_PASSPORT_LTP0",
    "main": "acf_uid=YOUR_UID; dy_did=YOUR_DY_DID; acf_stk=YOUR_STK; ...",
    "yuba": "acf_yb_uid=YOUR_UID; acf_yb_t=YOUR_YUBA_TOKEN; ..."
  },
  "cookieCloud": {
    "enabled": false,
    "endpoint": "https://your-cookie-cloud.example.com",
    "uuid": "YOUR_COOKIE_CLOUD_UUID",
    "password": "YOUR_COOKIE_CLOUD_PASSWORD",
    "cron": "0 5 0 * * *",
    "cryptoType": "legacy"
  },
  "ui": {
    "themeMode": "system"
  },
  "collectGift": {
    "enabled": true,
    "cron": "0 10 3,5 * * *"
  },
  "keepalive": {
    "enabled": true,
    "cron": "0 0 8 * * 3",
    "allocationMode": "fixed",
    "roomAllocations": {
      "123456": { "count": 1 },
      "789012": { "count": -1 }
    }
  },
  "doubleCard": {
    "enabled": false,
    "cron": "0 20 17,20,22,23 * * *",
    "giftScope": "glowStick",
    "participatingRoomIds": [123456],
    "allocationMode": "weighted",
    "roomAllocations": {
      "123456": { "weight": 50 },
      "789012": { "weight": 50 }
    }
  },
  "expiringGift": {
    "enabled": false,
    "cron": "0 45 23 * * *",
    "thresholdHours": 24,
    "allocationMode": "weighted",
    "roomAllocations": {
      "123456": { "weight": 1 },
      "789012": { "weight": 0 }
    }
  },
  "yubaCheckIn": {
    "enabled": false,
    "cron": "0 23 0 * * *",
    "mode": "followed"
  }
}
