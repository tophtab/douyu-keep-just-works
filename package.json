{
  "name": "douyu-keep-just-works",
  "version": "3.7.0",
  "description": "斗鱼粉丝牌保活工具，it just works.",
  "author": "tophtab",
  "contributors": [
    {
      "name": "Curtion"
    }
  ],
  "license": "UNLICENSED",
  "repository": "https://github.com/tophtab/douyu-keep-just-works.git",
  "scripts": {
    "lint": "eslint \"src/**/*.{js,ts,vue}\" \"test/**/*.js\" eslint.config.mjs",
    "type-check": "npm run type-check:docker && npm run type-check:webui",
    "type-check:docker": "tsc -p tsconfig.docker.json --noEmit",
    "type-check:webui": "vue-tsc -p tsconfig.webui.json --noEmit",
    "test:contracts": "node --test test/*.test.js",
    "test": "npm run test:contracts && npm run build:docker",
    "build": "npm run build:docker",
    "build:webui": "npm run type-check:webui && vite build",
    "build:docker": "rm -rf build/docker && npm run build:webui && tsc -p tsconfig.docker.json",
    "start": "node build/docker/docker/index.js"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "cron": "^4.4.0",
    "cron-parser": "^5.5.0",
    "express": "^5.2.1",
    "qrcode": "^1.5.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.1",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^10.4.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vue": "^3.5.35",
    "vue-tsc": "^3.2.8"
  },
  "overrides": {
    "@typescript-eslint/typescript-estree": {
      "minimatch": "^9.0.9"
    }
  }
}
